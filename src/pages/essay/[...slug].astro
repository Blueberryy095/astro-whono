---
import { render } from 'astro:content';
import { getPublished, isReservedSlug } from '../../lib/content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { createWithBase } from '../../utils/format';

export async function getStaticPaths() {
  const base = import.meta.env.BASE_URL ?? '/';
  const withBase = createWithBase(base);
  
  // 1. 获取所有已发布的随笔并按时间排序
  const essays = await getPublished('essay', {
    orderBy: (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  });
  
  // 2. 核心安检：过滤掉系统保留路径，并且过滤掉被你标记为 archive: false 的文章
  const archiveEssays = essays.filter((entry) => 
    !isReservedSlug(entry.data.slug ?? entry.id) && entry.data.archive !== false
  );
  
  return archiveEssays.map((entry, index) => {
    // 3. 安全获取上一篇和下一篇，防止首尾越界 Bug
    const prevEntry = index > 0 ? archiveEssays[index - 1] : null;
    const nextEntry = index < archiveEssays.length - 1 ? archiveEssays[index + 1] : null;
    
    return {
      params: { slug: entry.data.slug ?? entry.id },
      props: {
        entry,
        prev: prevEntry
          ? { href: withBase(`/archive/${prevEntry.data.slug ?? prevEntry.id}/`), title: prevEntry.data.title }
          : null,
        next: nextEntry
          ? { href: withBase(`/archive/${nextEntry.data.slug ?? nextEntry.id}/`), title: nextEntry.data.title }
          : null
      }
    };
  });
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<ArticleLayout entry={entry} Content={Content} prev={prev} next={next} />